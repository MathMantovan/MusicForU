@model List<MusicForU.Application.DTOs.SongResultDto>
@{
    ViewData["Title"] = "Início";
    var query = ViewBag.Query as string;
    var favIds = ViewBag.FavoriteSongIds as List<int> ?? new List<int>();
    var favSongs = ViewBag.FavoriteSongs as List<MusicForU.Application.DTOs.FavoriteSongDto>
        ?? new List<MusicForU.Application.DTOs.FavoriteSongDto>();
    var allSongs = ViewBag.AllSongs as List<MusicForU.Application.DTOs.SongResultDto>
        ?? new List<MusicForU.Application.DTOs.SongResultDto>();
    var playlists = ViewBag.Playlists as List<MusicForU.Application.DTOs.PlaylistDto>
        ?? new List<MusicForU.Application.DTOs.PlaylistDto>();
}

<h2>Buscar Músicas</h2>

<form method="get" asp-action="Index" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" value="@query" class="form-control" placeholder="Digite o nome da música..." />
        <button type="submit" class="btn btn-primary">Buscar</button>
    </div>
</form>

@if (Model.Any())
{
    <h4>Resultados da busca</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Música</th>
                <th>Álbum</th>
                <th>Banda</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.Title</td>
                    <td>@s.Album</td>
                    <td>@s.Band</td>
                    <td class="d-flex gap-1">
                        @if (favIds.Contains(s.Id))
                        {
                            <span class="text-danger">&#9829;</span>
                        }
                        else
                        {
                            <form method="post" asp-action="FavoriteSong" style="display:inline">
                                <input type="hidden" name="songId" value="@s.Id" />
                                <input type="hidden" name="q" value="@query" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">&#9825;</button>
                            </form>
                        }
                        @if (playlists.Any())
                        {
                            <div class="dropdown d-inline">
                                <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">+ Playlist</button>
                                <ul class="dropdown-menu">
                                    @foreach (var pl in playlists)
                                    {
                                        <li>
                                            <form method="post" asp-action="AddToPlaylist">
                                                <input type="hidden" name="playlistId" value="@pl.Id" />
                                                <input type="hidden" name="songId" value="@s.Id" />
                                                <input type="hidden" name="q" value="@query" />
                                                <button type="submit" class="dropdown-item">@pl.Name</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else if (!string.IsNullOrWhiteSpace(query))
{
    <div class="alert alert-info">Nenhuma música encontrada para "<strong>@query</strong>".</div>
}

<hr />

<h4>Todas as Músicas</h4>
<div style="max-height: 350px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 6px;">
    <table class="table table-hover table-sm mb-0">
        <thead class="table-light" style="position: sticky; top: 0;">
            <tr>
                <th>Música</th>
                <th>Álbum</th>
                <th>Banda</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in allSongs)
            {
                <tr>
                    <td>@s.Title</td>
                    <td>@s.Album</td>
                    <td>@s.Band</td>
                    <td class="d-flex gap-1">
                        @if (favIds.Contains(s.Id))
                        {
                            <span class="text-danger">&#9829;</span>
                        }
                        else
                        {
                            <form method="post" asp-action="FavoriteSong" style="display:inline">
                                <input type="hidden" name="songId" value="@s.Id" />
                                <input type="hidden" name="q" value="@query" />
                                <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1">&#9825;</button>
                            </form>
                        }
                        @if (playlists.Any())
                        {
                            <div class="dropdown d-inline">
                                <button class="btn btn-outline-primary btn-sm py-0 px-1 dropdown-toggle" type="button" data-bs-toggle="dropdown">+</button>
                                <ul class="dropdown-menu">
                                    @foreach (var pl in playlists)
                                    {
                                        <li>
                                            <form method="post" asp-action="AddToPlaylist">
                                                <input type="hidden" name="playlistId" value="@pl.Id" />
                                                <input type="hidden" name="songId" value="@s.Id" />
                                                <input type="hidden" name="q" value="@query" />
                                                <button type="submit" class="dropdown-item">@pl.Name</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<hr />

<h4>Meus Favoritos</h4>
@if (favSongs.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Música</th>
                <th>Álbum</th>
                <th>Banda</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fav in favSongs)
            {
                <tr>
                    <td>@fav.Title</td>
                    <td>@fav.Album</td>
                    <td>@fav.Band</td>
                    <td>
                        <form method="post" asp-action="RemoveFavoriteSong" style="display:inline">
                            <input type="hidden" name="songId" value="@fav.SongId" />
                            <input type="hidden" name="q" value="@query" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm">&#10005; Remover</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Você ainda não favoritou nenhuma música.</p>
}

<hr />

<h4>Minhas Playlists</h4>

<form method="post" asp-action="CreatePlaylist" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="name" class="form-control" placeholder="Nome da nova playlist..." required />
        <input type="hidden" name="q" value="@query" />
        <button type="submit" class="btn btn-success">Criar Playlist</button>
    </div>
</form>

@if (playlists.Any())
{
    @foreach (var pl in playlists)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold">@pl.Name</div>
            <div class="card-body p-0">
                @if (pl.Songs.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Música</th>
                                <th>Álbum</th>
                                <th>Banda</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in pl.Songs)
                            {
                                <tr>
                                    <td>@s.Title</td>
                                    <td>@s.Album</td>
                                    <td>@s.Band</td>
                                    <td>
                                        <form method="post" asp-action="RemoveFromPlaylist" style="display:inline">
                                            <input type="hidden" name="playlistId" value="@pl.Id" />
                                            <input type="hidden" name="songId" value="@s.Id" />
                                            <input type="hidden" name="q" value="@query" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">&#10005;</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">Playlist vazia. Adicione músicas pela busca ou lista acima.</p>
                }
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">Você ainda não criou nenhuma playlist.</p>
}
